# ============================================================
#  ZenXYT Bot — Environment Variables Example
#  USAGE: copy this to .env and fill in your values.
# ============================================================

# ──────────────────────────────────────────────────────────
# NVIDIA API (Nemotron)
# Get yours at: https://integrate.api.nvidia.com
# ──────────────────────────────────────────────────────────
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
NVIDIA_MAX_TOKENS=4096
NVIDIA_TEMPERATURE=0.3
NVIDIA_FREQ_PENALTY=0.3
NVIDIA_API_TIMEOUT=120

# ──────────────────────────────────────────────────────────
# GOOGLE GEMINI API
# Get yours at: https://aistudio.google.com/apikey
# ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# ──────────────────────────────────────────────────────────
# YOUTUBE OAUTH
# ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_SECRETS_PATH=client_secrets.json
GOOGLE_TOKEN_PICKLE_PATH=token.pickle
COOKIES_FILE=cookies.txt

# ──────────────────────────────────────────────────────────
# GENERATION MODE (nvidia | gemini | debate)
# ──────────────────────────────────────────────────────────
GENERATION_MODE=debate

# ──────────────────────────────────────────────────────────
# VIDEO TYPE FILTER (shorts | longs | all)
# ──────────────────────────────────────────────────────────
VIDEO_TYPE_FILTER=all

# ──────────────────────────────────────────────────────────
# PROCESSING CONFIG
# ──────────────────────────────────────────────────────────
VIDEO_FORMAT=worst[height<=360][ext=mp4]/worst[ext=mp4]
MAX_DURATION_SECONDS=65
MAX_RETRIES=3
BACKOFF_BASE_SECONDS=15
INTER_VIDEO_SECONDS=45
WORKERS=2
SKIP_DONE=true
PROGRESS_LOG=progress.json
LOG_FILE=bot.log
